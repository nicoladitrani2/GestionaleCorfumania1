generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agency {
  id          String                      @id @default(cuid())
  name        String                      @unique
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  defaultCommission Float                 @default(0)
  commissionType    String                @default("PERCENTAGE") // PERCENTAGE or FIXED
  commissions ExcursionAgencyCommission[]
  transferCommissions TransferAgencyCommission[]
  users       User[]
  participants Participant[] @relation("ParticipantAgency")
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  password           String
  code               String        @unique @default(cuid())
  firstName          String?
  lastName           String?
  role               String        @default("USER")
  mustChangePassword Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  agencyId           String?
  auditLogs          AuditLog[]
  participants       Participant[]
  agency             Agency?       @relation(fields: [agencyId], references: [id])
  assignedTaxBookings TaxBooking[] @relation("AssignedTaxBookings")
  taxImportBatchesCreated TaxImportBatch[]
  assignedParticipants Participant[] @relation("AssignedParticipants")
  createdTransfers   Transfer[]    @relation("UserCreatedTransfers")
}

model Excursion {
  id                   String                      @id @default(cuid())
  name                 String?
  startDate            DateTime?
  endDate              DateTime?
  confirmationDeadline DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  priceAdult           Float?                      @default(0)
  priceChild           Float?                      @default(0)
  tax                  Float?                      @default(0)
  maxParticipants      Int?
  auditLogs            AuditLog[]
  agencyCommissions    ExcursionAgencyCommission[]
  participants         Participant[]
  priceTiers           ExcursionPriceTier[]
  transferDepartureLocation String?
  transferDestinationLocation String?
  transferTime         String?
}

model ExcursionPriceTier {
  id         String   @id @default(cuid())
  excursionId String
  label      String
  price      Float    @default(0)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  excursion  Excursion @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@unique([excursionId, label])
}

model ExcursionAgencyCommission {
  id                   String    @id @default(cuid())
  excursionId          String
  agencyId             String
  commissionPercentage Float     @default(0)
  commissionType       String    @default("PERCENTAGE") // PERCENTAGE or FIXED
  agency               Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  excursion            Excursion @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@unique([excursionId, agencyId])
}

model Transfer {
  id                   String        @id @default(cuid())
  name                 String
  date                 DateTime
  endDate              DateTime?
  confirmationDeadline DateTime?
  pickupLocation       String?
  dropoffLocation      String?
  supplier             String
  priceAdult           Float         @default(0)
  priceChild           Float         @default(0)
  maxParticipants      Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  returnPickupLocation String?
  agencyCommissions    TransferAgencyCommission[]
  auditLogs            AuditLog[]
  participants         Participant[]
  priceTiers           TransferPriceTier[]
  approvalStatus       String        @default("APPROVED") // PENDING, APPROVED, REJECTED
  createdById          String?
  createdBy            User?         @relation("UserCreatedTransfers", fields: [createdById], references: [id])
}

model TransferPriceTier {
  id         String   @id @default(cuid())
  transferId String
  label      String
  price      Float    @default(0)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@unique([transferId, label])
}

model TransferAgencyCommission {
  id                   String    @id @default(cuid())
  transferId           String
  agencyId             String
  commissionPercentage Float     @default(0)
  commissionType       String    @default("PERCENTAGE") // PERCENTAGE or FIXED
  agency               Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  transfer             Transfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@unique([transferId, agencyId])
}

model ExcursionTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rental {
  id        String        @id @default(cuid())
  name      String
  type      String        // CAR, MOTO, BOAT
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  auditLogs AuditLog[]
  participants Participant[]
}

model Participant {
  id                    String   @id @default(cuid())
  name                  String
  email                 String?
  phone                 String?
  adults                Int
  children              Int
  infants               Int
  countsByTier          Json?
  totalPrice            Float
  paidAmount            Float
  paymentMethod         String
  paymentStatus         String   // PENDING, PAID, PARTIAL
  status                String   // ACTIVE, CANCELLED, REFUNDED
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  excursionId           String?
  userId                String
  excursion             Excursion? @relation(fields: [excursionId], references: [id])
  user                  User       @relation(fields: [userId], references: [id])
  pickupLocation        String?
  pickupTime            String?
  dropoffLocation       String?
  returnPickupLocation  String?
  returnDropoffLocation String?
  returnDate            DateTime?
  returnTime            String?
  isRoundTrip           Boolean @default(false)
  transferId            String?
  transfer              Transfer? @relation(fields: [transferId], references: [id])
  rentalId              String?
  rental                Rental? @relation(fields: [rentalId], references: [id])
  roomNumber            String?
  supplier              String?
  nationality           String?
  paymentType           String? // FULL_PAYMENT, DEPOSIT, OPTION, REFUNDED
  ticketNumber          String?
  bookingDate           DateTime @default(now()) // Cash Basis Date
  tax                   Float    @default(0)     // Tax field
  specialServiceType    String? // BRACELET, CITY_TAX, AC
  clientId              String?
  client                Client?   @relation(fields: [clientId], references: [id])
  assignedToId          String?
  assignedTo            User?    @relation("AssignedParticipants", fields: [assignedToId], references: [id])

  // Campi specifici per i noleggi
  rentalType             String?
  rentalStartDate        DateTime?
  rentalEndDate          DateTime?
  licenseType            String?
  insurancePrice         Float    @default(0)
  supplementPrice        Float    @default(0)
  assistantCommission    Float    @default(0)
  assistantCommissionType String?
  needsTransfer          Boolean  @default(false)
  commissionPercentage   Float    @default(0)
  agencyId               String?
  agency                 Agency?  @relation("ParticipantAgency", fields: [agencyId], references: [id])
  approvalStatus         String   @default("APPROVED") // PENDING, APPROVED, REJECTED
  
  // Campi anagrafici aggiuntivi
  firstName             String?
  lastName              String?
  dateOfBirth           DateTime?
  docNumber             String?
  docType               String?
}

model Client {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phoneNumber  String?
  nationality  String?
  serviceType  String?
  isManuallyContacted Boolean @default(false)
  lastEmailSentAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  participants Participant[]
  @@unique([email])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model AuditLog {
  id          String      @id @default(cuid())
  action      String      // CREATE, UPDATE, DELETE
  entityType  String      // EXCURSION, PARTICIPANT, USER
  entityId    String
  userId      String
  details     String      // JSON string of changes
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id])
  excursion   Excursion?  @relation(fields: [excursionId], references: [id])
  excursionId String?
  transfer    Transfer?   @relation(fields: [transferId], references: [id])
  transferId  String?
  rental      Rental?     @relation(fields: [rentalId], references: [id])
  rentalId    String?
}

model TaxBooking {
  id          String   @id @default(cuid())
  nFile       String
  week        String   // Sheet name
  provenienza String   // "PRIVATO" | "AGENZIA"
  serviceCode Int      // 1=BRACCIALETTO, 2=TASSA_SOGGIORNO, 3=BRACCIALETTO+TASSA, 4=CAUZIONE
  pax         Int
  leadName    String
  room        String?
  totalAmount Float    @default(0)

  depositStatus String  @default("PENDING") // PENDING | RETURNED | RETAINED
  depositProcessedAt DateTime?
  
  importBatchId String?
  importBatch   TaxImportBatch? @relation(fields: [importBatchId], references: [id])
  backups       TaxBookingBackup[]

  assignedToId String?
  assignedTo   User?   @relation("AssignedTaxBookings", fields: [assignedToId], references: [id])
  
  customerPaid Boolean @default(false)
  adminPaid    Boolean @default(false)
  
  rawData      String  // JSON string for other details (flights, notes, etc.)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([nFile, week, serviceCode]) // Multiple records per booking/week (e.g. deposit)
}

model TaxImportBatch {
  id          String   @id @default(cuid())
  fileName    String?
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  rolledBackAt DateTime?

  taxBookings TaxBooking[]
  backups     TaxBookingBackup[]
}

model TaxBookingBackup {
  id              String   @id @default(cuid())
  batchId         String
  batch           TaxImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  taxBookingId    String
  taxBooking      TaxBooking @relation(fields: [taxBookingId], references: [id], onDelete: Cascade)
  prevImportBatchId String?
  snapshot        String
  createdAt       DateTime @default(now())

  @@unique([taxBookingId, batchId])
}
